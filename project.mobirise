          "_name": "gallery03",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"gallery3\" group=\"Gallery\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n      <header>Size</header>\n      <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n      <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"8\">\n      <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"4\">\n      <select title=\"Columns\" name=\"cardsWidth\">\n        <option value=\"12\">1</option>\n        <option value=\"6\">2</option>\n        <option value=\"4\">3</option>\n        <option value=\"3\" selected>4</option>\n        <option value=\"2\">6</option>\n      </select>\n      <header>Show/Hide</header>\n      <input type=\"checkbox\" name=\"showTitle\" title=\"Title\" checked>\n      <input type=\"checkbox\" name=\"showSubtitle\" title=\"Subtitle\" checked>\n      <header>Cards</header>\n      <input type=\"checkbox\" name=\"autoSize\" title=\"Auto Size\">\n      <input type=\"range\" name=\"imageHeight\" title=\"Height\" min=\"1\" max=\"5\" step=\"1\" value=\"4\" condition=\"autoSize\">\n      <input type=\"checkbox\" title=\"Spacing\" name=\"spacing\" checked>\n      <input type=\"checkbox\" name=\"showCardTitle\" title=\"Title\" checked>\n      <input type=\"checkbox\" name=\"showCardSubtitle\" title=\"Subtitle\" checked>\n      <header>Background</header>\n      <fieldset type=\"background\" parallax name=\"bg\" required>\n        <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n        <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n      </fieldset>\n      <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n      <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#edefeb\" condition=\"overlay && bg.type == 'image'\">\n      <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.6\" condition=\"overlay && bg.type == 'image'\">\n    </mbr-parameters>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\"></div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n      <div class=\"row justify-content-center\">\n        <div class=\"col-12 content-head\">\n          <div class=\"mbr-section-head mb-5\" mbr-if=\"showTitle || showSubtitle\">\n            <h4 class=\"mbr-section-title mbr-fonts-style align-center mb-0\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\">\n              <b>Ensino</b></h4>\n            <h5 class=\"mbr-section-subtitle mbr-fonts-style align-center mb-0 mt-4\" mbr-theme-style=\"display-7\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\">Material voltado para o ensino</h5>\n          </div>\n        </div>\n      </div>\n      <div class=\"row\">\n        <div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}} active\">\n          <div class=\"item-wrapper\">\n            <div class=\"item-img\">\n              <a href=\"C:\\Users\\PICHAU\\Desktop\\mobirise\\Buracos e empacotamento.html\" target=\"_blank\"><img src=\"@PROJECT_PATH@/assets/images/ensino-card-1.svg\" alt=\"https://quimicavisualufv.github.io/Quimica-Visual/Buracos%20e%20empacotamento.html\" title data-slide-to=\"0\" data-bs-slide-to=\"0\"></a>\n            </div>\n            <div class=\"item-content align-left\" mbr-if=\"showCardTitle || showCardSubtitle || showText || showButtons\">\n              <h5 class=\"item-title mbr-fonts-style mt-3 mb-3\" mbr-theme-style=\"display-7\" data-app-selector=\".item-title, .mbr-section-btn\" mbr-if=\"showCardTitle\">\n                <b>Buracos e empacotamento</b></h5>\n              <h2 class=\"item-subtitle mbr-fonts-style mb-3\" mbr-theme-style=\"display-7\" data-app-selector=\".item-subtitle, .mbr-section-btn\" mbr-if=\"showCardSubtitle\">Tipos de buracos em células unitárias, empacotamentos e relação com coordenação e ocupação.</h2>\n            </div>\n          </div>\n        </div>\n        <div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n          <div class=\"item-wrapper\">\n            <div class=\"item-img\">\n              <a href=\"https://quimicavisualufv.github.io/Quimica-Visual/C%C3%89LULAS%20PRIMITIVAS%2C%20SISTEMAS%20BRAVAIS%20E%20C%C3%89LULA%20DE%20Wigner.html\" target=\"_blank\"><img src=\"@PROJECT_PATH@/assets/images/ensino-card-2.svg\" alt=\"https://quimicavisualufv.github.io/Quimica-Visual/C%C3%89LULAS%20PRIMITIVAS%2C%20SISTEMAS%20BRAVAIS%20E%20C%C3%89LULA%20DE%20Wigner.html\" title data-slide-to=\"1\" data-bs-slide-to=\"1\"></a>\n            </div>\n            <div class=\"item-content align-left\" mbr-if=\"showCardTitle || showCardSubtitle || showText || showButtons\">\n              <h5 class=\"item-title mbr-fonts-style mt-3 mb-3\" mbr-theme-style=\"display-7\" data-app-selector=\".item-title, .mbr-section-btn\" mbr-if=\"showCardTitle\"><div><b>Células Primitivas, Sistemas de Bravais e Célula de Wigner (GUIA)</b></div></h5>\n              <h2 class=\"item-subtitle mbr-fonts-style mb-3\" mbr-theme-style=\"display-7\" data-app-selector=\".item-subtitle, .mbr-section-btn\" mbr-if=\"showCardSubtitle\">Tipos de células, sistemas de Bravais e introdução à construção de Wigner–Seitz em contexto cristalográfico</h2>\n            </div>\n          </div>\n        </div>\n        <div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n          <div class=\"item-wrapper\">\n            <div class=\"item-img\">\n              <a href=\"https://quimicavisualufv.github.io/Quimica-Visual/c%C3%A9lulas.html\" target=\"_blank\"><img src=\"@PROJECT_PATH@/assets/images/ensino-card-3.svg\" alt=\"https://quimicavisualufv.github.io/Quimica-Visual/c%C3%A9lulas.html\" title data-slide-to=\"2\" data-bs-slide-to=\"2\"></a>\n            </div>\n            <div class=\"item-content align-left\" mbr-if=\"showCardTitle || showCardSubtitle || showText || showButtons\">\n              <h5 class=\"item-title mbr-fonts-style mt-3 mb-3\" mbr-theme-style=\"display-7\" data-app-selector=\".item-title, .mbr-section-btn\" mbr-if=\"showCardTitle\">\n                <b>Parâmetros de rede (GUIA)</b></h5>\n              <h2 class=\"item-subtitle mbr-fonts-style mb-3\" mbr-theme-style=\"display-7\" data-app-selector=\".item-subtitle, .mbr-section-btn\" mbr-if=\"showCardSubtitle\">Célula, célula unitária, modelo de esferas, parâmetro de rede, ângulos (α, β, γ) e rede cristalina.</h2>\n              \n            </div>\n          </div>\n        </div>\n        <div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n          <div class=\"item-wrapper\">\n            <div class=\"item-img\">\n              <a href=\"https://quimicavisualufv.github.io/Quimica-Visual/Geometria%20cristalogr%C3%A1fica.html\" target=\"_blank\"><img src=\"@PROJECT_PATH@/assets/images/ensino-card-4.svg\" alt=\"https://quimicavisualufv.github.io/Quimica-Visual/Geometria%20cristalogr%C3%A1fica.html\" title data-slide-to=\"3\" data-bs-slide-to=\"3\"></a>\n            </div>\n            <div class=\"item-content align-left\" mbr-if=\"showCardTitle || showCardSubtitle || showText || showButtons\">\n              <h5 class=\"item-title mbr-fonts-style mt-3 mb-3\" mbr-theme-style=\"display-7\" data-app-selector=\".item-title, .mbr-section-btn\" mbr-if=\"showCardTitle\">\n                <b>Geometria Cristalográfica</b></h5>\n              <h2 class=\"item-subtitle mbr-fonts-style mb-3\" mbr-theme-style=\"display-7\" data-app-selector=\".item-subtitle, .mbr-section-btn\" mbr-if=\"showCardSubtitle\">Geometrias das células (cúbica, tetragonal, ortorrômbica, etc.) e como elas aparecem em redes cristalinas.</h2>\n            </div>\n          </div>\n        </div><div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n          <div class=\"item-wrapper\">\n            <div class=\"item-img\">\n              <a href=\"https://quimicavisualufv.github.io/Quimica-Visual/Geometria%20molecular%20-%20passo%20a%20passo.html\"><img src=\"@PROJECT_PATH@/assets/images/ensino-card-5.svg\" alt=\"https://quimicavisualufv.github.io/Quimica-Visual/Geometria%20molecular%20-%20passo%20a%20passo.html\" title data-slide-to=\"4\" data-bs-slide-to=\"4\"></a>\n            </div>\n            <div class=\"item-content align-left\" mbr-if=\"showCardTitle || showCardSubtitle || showText || showButtons\">\n              <h5 class=\"item-title mbr-fonts-style mt-3 mb-3\" mbr-theme-style=\"display-7\" data-app-selector=\".item-title, .mbr-section-btn\" mbr-if=\"showCardTitle\"><b>Geometria molecular (GUIA)</b></h5>\n              <h2 class=\"item-subtitle mbr-fonts-style mb-3\" mbr-theme-style=\"display-7\" data-app-selector=\".item-subtitle, .mbr-section-btn\" mbr-if=\"showCardSubtitle\">Tutorial guiado para montar e entender os tipos mais comum de geometria molecular.</h2>\n            </div>\n          </div>\n        </div><div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n          <div class=\"item-wrapper\">\n            <div class=\"item-img\">\n              <a href=\"https://quimicavisualufv.github.io/Quimica-Visual/Polaridade%20molecular%20-%20tutorial%20guiado%20passo%20a%20passo.html\"><img src=\"@PROJECT_PATH@/assets/images/ensino-card-7.svg\" alt=\"https://quimicavisualufv.github.io/Quimica-Visual/Polaridade%20molecular%20-%20tutorial%20guiado%20passo%20a%20passo.html\" title data-slide-to=\"5\" data-bs-slide-to=\"5\"></a>\n            </div>\n            <div class=\"item-content align-left\" mbr-if=\"showCardTitle || showCardSubtitle || showText || showButtons\">\n              <h5 class=\"item-title mbr-fonts-style mt-3 mb-3\" mbr-theme-style=\"display-7\" data-app-selector=\".item-title, .mbr-section-btn\" mbr-if=\"showCardTitle\"><div><b>Polaridade molecular (GUIA)</b></div></h5>\n              <h2 class=\"item-subtitle mbr-fonts-style mb-3\" mbr-theme-style=\"display-7\" data-app-selector=\".item-subtitle, .mbr-section-btn\" mbr-if=\"showCardSubtitle\">Momento dipolar, vetores de ligação e geometria molecular para decidir polaridade com apoio visual.</h2>\n            </div>\n          </div>\n        </div><div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n          <div class=\"item-wrapper\">\n            <div class=\"item-img\">\n              <a href=\"https://quimicavisualufv.github.io/Quimica-Visual/Geometria%20molecular.html\"><img src=\"@PROJECT_PATH@/assets/images/ensino-card-6.svg\" alt=\"https://quimicavisualufv.github.io/Quimica-Visual/Geometria%20molecular.html\" title data-slide-to=\"6\" data-bs-slide-to=\"6\"></a>\n            </div>\n            <div class=\"item-content align-left\" mbr-if=\"showCardTitle || showCardSubtitle || showText || showButtons\">\n              <h5 class=\"item-title mbr-fonts-style mt-3 mb-3\" mbr-theme-style=\"display-7\" data-app-selector=\".item-title, .mbr-section-btn\" mbr-if=\"showCardTitle\"><b>Geometria molecular</b></h5>\n              <h2 class=\"item-subtitle mbr-fonts-style mb-3\" mbr-theme-style=\"display-7\" data-app-selector=\".item-subtitle, .mbr-section-btn\" mbr-if=\"showCardSubtitle\">\n                Visualizador simples de moléculas, com representação de seus ângulos, elétrons livres, geometria e arranjo espacial.</h2>\n            </div>\n          </div>\n        </div><div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n          <div class=\"item-wrapper\">\n            <div class=\"item-img\">\n              <a href=\"https://quimicavisualufv.github.io/Quimica-Visual/Quebra-cabe%C3%A7a%20ionico%20covalente.html\"><img src=\"@PROJECT_PATH@/assets/images/ensino-card-8.svg\" alt=\"https://quimicavisualufv.github.io/Quimica-Visual/Quebra-cabe%C3%A7a%20ionico%20covalente.html\" title data-slide-to=\"7\" data-bs-slide-to=\"7\"></a>\n            </div>\n            <div class=\"item-content align-left\" mbr-if=\"showCardTitle || showCardSubtitle || showText || showButtons\">\n              <h5 class=\"item-title mbr-fonts-style mt-3 mb-3\" mbr-theme-style=\"display-7\" data-app-selector=\".item-title, .mbr-section-btn\" mbr-if=\"showCardTitle\"><b>Quebra-cabeça iônico covalente</b></h5>\n              <h2 class=\"item-subtitle mbr-fonts-style mb-3\" mbr-theme-style=\"display-7\" data-app-selector=\".item-subtitle, .mbr-section-btn\" mbr-if=\"showCardSubtitle\">Arraste, combine e teste conceito: ligação iônica vs covalente, propriedades e exemplos clássicos.</h2>\n            </div>\n          </div>\n        </div><div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n          <div class=\"item-wrapper\">\n            <div class=\"item-img\">\n              <a href=\"https://quimicavisualufv.github.io/Quimica-Visual/Redes%20Cristalinas.html\" target=\"_blank\"><img src=\"@PROJECT_PATH@/assets/images/ensino-card-9.svg\" alt=\"https://quimicavisualufv.github.io/Quimica-Visual/Redes%20Cristalinas.html\" title data-slide-to=\"8\" data-bs-slide-to=\"8\"></a>\n            </div>\n            <div class=\"item-content align-left\" mbr-if=\"showCardTitle || showCardSubtitle || showText || showButtons\">\n              <h5 class=\"item-title mbr-fonts-style mt-3 mb-3\" mbr-theme-style=\"display-7\" data-app-selector=\".item-title, .mbr-section-btn\" mbr-if=\"showCardTitle\"><b>Redes Cristalinas</b></h5>\n              <h2 class=\"item-subtitle mbr-fonts-style mb-3\" mbr-theme-style=\"display-7\" data-app-selector=\".item-subtitle, .mbr-section-btn\" mbr-if=\"showCardSubtitle\">Translação, pontos de rede e como a repetição gera estruturas cristalinas, com exemplos, contraexemplos e modo de criação livre.</h2>\n            </div>\n          </div>\n        </div><div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n          <div class=\"item-wrapper\">\n            <div class=\"item-img\">\n              <a href=\"https://quimicavisualufv.github.io/Quimica-Visual/Simetria%20e%20f%C3%B3rmula%20unit%C3%A1ria.html\" target=\"_blank\"><img src=\"@PROJECT_PATH@/assets/images/ensino-card-10.svg\" alt=\"https://quimicavisualufv.github.io/Quimica-Visual/Simetria%20e%20f%C3%B3rmula%20unit%C3%A1ria.html\" title data-slide-to=\"9\" data-bs-slide-to=\"9\"></a>\n            </div>\n            <div class=\"item-content align-left\" mbr-if=\"showCardTitle || showCardSubtitle || showText || showButtons\">\n              <h5 class=\"item-title mbr-fonts-style mt-3 mb-3\" mbr-theme-style=\"display-7\" data-app-selector=\".item-title, .mbr-section-btn\" mbr-if=\"showCardTitle\"><div><b>Simetria e fórmula unitária</b></div></h5>\n              <h2 class=\"item-subtitle mbr-fonts-style mb-3\" mbr-theme-style=\"display-7\" data-app-selector=\".item-subtitle, .mbr-section-btn\" mbr-if=\"showCardSubtitle\">Operações de simetria e translação, contagem fracionária de átomos para chegar na fórmula mínima da célula unitária e representações em 3D.</h2>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>",
